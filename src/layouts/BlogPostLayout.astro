---
/*
 * Copyright (C) Aditya 2023-2026 <github.com/TriStaRvOiD>
 */
import BaseLayout from "./BaseLayout.astro";

interface Props {
  frontmatter: {
    title: string;
    pubDate: Date;
    description: string;
    tags?: string[];
  };
}

const { frontmatter } = Astro.props;
---

<BaseLayout title={`${frontmatter.title} | TriStaRvOiD`} description={frontmatter.description}>
  <article class="blog-post">
    <header>
      <a href="/blog/" class="back">&larr; Back</a>
      <h1>{frontmatter.title}</h1>
      <time datetime={frontmatter.pubDate.toISOString()}>
        {frontmatter.pubDate.toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
        })}
      </time>
      {frontmatter.tags && frontmatter.tags.length > 0 && (
        <div class="tags">
          {frontmatter.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      )}
    </header>
    <div class="content">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    max-width: 42rem;
    margin: 0 auto;
    padding: 2rem;
  }

  .back {
    font-family: "Josefin Sans", sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-secondary);
    display: inline-block;
    margin-bottom: 2rem;
  }

  .back:hover {
    color: var(--text);
  }

  h1 {
    font-size: 1.8rem;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  time {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    background-color: var(--bg-secondary);
    color: var(--text-secondary);
  }

  .content {
    margin-top: 2rem;
    font-family: "Lora", serif;
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .content :global(h2) {
    font-family: "Lato", sans-serif;
    font-size: 1.4rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .content :global(h3) {
    font-family: "Lato", sans-serif;
    font-size: 1.15rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .content :global(p) {
    margin-bottom: 1rem;
  }

  .content :global(code) {
    font-size: 0.9em;
    padding: 0.15rem 0.3rem;
    border-radius: 3px;
    background-color: var(--bg-secondary);
  }

  .content :global(pre) {
    padding: 1rem;
    border-radius: 6px;
    overflow-x: auto;
    margin-bottom: 1rem;
    background-color: var(--bg-secondary);
  }

  .content :global(pre code) {
    padding: 0;
    background: none;
  }

  .content :global(ul),
  .content :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .content :global(li) {
    margin-bottom: 0.25rem;
  }

  .content :global(blockquote) {
    border-left: 3px solid var(--border);
    padding-left: 1rem;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }
</style>
