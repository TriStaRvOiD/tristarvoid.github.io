import BaseLayout from "../layouts/BaseLayout.astro";
import ProfileVideo from "../components/ProfileVideo.astro";
import SocialLinks from "../components/SocialLinks.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
---

<BaseLayout>
  <section class="hero">
    <div class="animate-entrance"><ProfileVideo /></div>
    <h1 class="animate-entrance">TriStaRvOiD</h1>
    <p class="tagline animate-entrance">Mobile app engineer</p>
    <div class="animate-entrance"><SocialLinks /></div>
  </section>

  {projects.length > 0 && (
    <section class="featured">
      <div class="section-header animate-scroll">
        <h2>Projects</h2>
        <a href="/projects/">View all</a>
      </div>
      <div class="project-grid">
        {projects.slice(0, 2).map((project) => (
          <div class="animate-scroll">
            <ProjectCard {...project} />
          </div>
        ))}
      </div>
    </section>
  )}

</BaseLayout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 6rem 2rem 4rem;
    text-align: center;
  }

  h1 {
    font-family: "Josefin Sans", sans-serif;
    font-size: 2rem;
    margin-top: 1.5rem;
    letter-spacing: 0.02em;
  }

  .tagline {
    font-family: "Josefin Sans", sans-serif;
    color: var(--text-secondary);
    margin-top: 0.5rem;
    margin-bottom: 1.5rem;
    font-size: 1rem;
  }

  .featured {
    max-width: 58rem;
    margin: 0 auto;
    padding: 2rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.5rem;
  }

  .section-header h2 {
    font-family: "Josefin Sans", sans-serif;
    font-size: 1.2rem;
    font-weight: 600;
  }

  .section-header a {
    font-family: "Josefin Sans", sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-secondary);
  }

  .section-header a:hover {
    color: var(--text);
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }


</style>
