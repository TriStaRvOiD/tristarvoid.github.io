import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
---

<BaseLayout title="Projects | TriStaRvOiD" description="Projects by TriStaRvOiD">
  <section class="projects">
    <h1 class="animate-entrance">Projects</h1>
    <div class="grid">
      {projects.map((project) => (
        <div class="animate-scroll">
          <ProjectCard {...project} />
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .projects {
    max-width: 58rem;
    margin: 0 auto;
    padding: 2rem;
  }

  h1 {
    font-family: "Josefin Sans", sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 2rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
</style>
