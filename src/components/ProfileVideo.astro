---

<video
  class="profile-video"
  width="210"
  height="210"
  poster="/assets/profile-video-poster.jpg"
  preload="metadata"
  playsinline
>
  <source src="/assets/profile-video.mp4#t=0.001" type="video/mp4" />
</video>

<style>
  .profile-video {
    width: 210px;
    height: 210px;
    border-radius: 50%;
    object-fit: cover;
    user-select: none;
    cursor: pointer;
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const video = document.querySelector(".profile-video") as HTMLVideoElement | null;
    if (!video) return;

    // Safari doesn't honor preload="metadata" on dynamically inserted media
    // (Astro view-transition swap). Kick off loading explicitly so play() is
    // responsive on first click.
    if (video.readyState === 0) video.load();

    const tryPlay = () => {
      const p = video.play();
      if (p && typeof p.catch === "function") {
        p.catch(() => {
          const onCanPlay = () => { video.play().catch(() => {}); };
          video.addEventListener("canplay", onCanPlay, { once: true });
          video.load();
        });
      }
    };

    video.addEventListener("click", () => {
      if (video.paused) tryPlay();
      else video.pause();
    });
  });
</script>
