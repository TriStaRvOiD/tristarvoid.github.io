---
/*
 * Copyright (C) Aditya 2023-2026 <github.com/TriStaRvOiD>
 */
interface Props {
  name: string;
  description: string;
  tech: string[];
  github: string;
  live?: string;
}

const { name, description, tech, github, live } = Astro.props;
---

<article class="project-card">
  <h3>
    <a href={github} target="_blank" rel="noopener noreferrer">{name}</a>
  </h3>
  <p>{description}</p>
  <div class="tech-tags">
    {tech.map((t) => <span class="tag">{t}</span>)}
  </div>
  {live && (
    <a href={live} target="_blank" rel="noopener noreferrer" class="live-link">
      Live
    </a>
  )}
</article>

<style>
  .project-card {
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: border-color 0.2s ease;
  }

  .project-card:hover {
    border-color: var(--text-secondary);
  }

  h3 {
    margin-bottom: 0.5rem;
    font-size: 1.1rem;
  }

  p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }

  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    background-color: var(--bg-secondary);
    color: var(--text-secondary);
  }

  .live-link {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .live-link:hover {
    color: var(--text);
  }
</style>
